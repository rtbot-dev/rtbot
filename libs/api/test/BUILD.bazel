load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

cc_library(
    name = "parity_helper",
    hdrs = ["parity_helper.h"],
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = [
        "//libs/api:rtbot-api",
        "@catch2",
    ],
)

cc_test(
    name = "test",
    srcs = glob([
        "**/*.cpp",
        "**/*.hpp",
        "**/*.h",
    ], allow_empty = True),
    data = glob([
        "**/*.json",
        "**/*.csv",
    ], allow_empty = True) + [
        "//examples/data:ppg.csv",
        "//examples/data:program-test-1.json",
        "//examples/data:program-test-2.json",
        "//examples/data:program-test-3.json",
        "//examples/data:program-test-4.json",
        "//examples/data:program-test-5.json",
        "//examples/data:program-test-6.json",
    ],
    # defines = ["CATCH_CONFIG_MAIN"],
    deps = [
        "//libs/api:rtbot-api",
        "@catch2",
    ],
)
