# Output to dist/ instead of bazel-bin/, bazel-out/, etc.
build --symlink_prefix=dist/

# Workspace status: derive version metadata from git tags/commit
build --workspace_status_command=./tools/workspace_status.sh

# Enable host OS-specific configs (build:linux, build:macos, build:windows, ...)
build --enable_platform_specific_config

# Linux clang + C++17
build:linux --repo_env=CC=clang
build:linux --cxxopt=-std=c++17
build:linux --host_cxxopt=-std=c++17
build:linux --cxxopt=-Wno-c++11-narrowing

# macOS clang + C++17
build:macos --repo_env=CC=clang
build:macos --cxxopt=-std=c++17
build:macos --host_cxxopt=-std=c++17
build:macos --cxxopt=-Wno-c++11-narrowing
build:macos --cxxopt=-stdlib=libc++
build:macos --host_cxxopt=-stdlib=libc++
build:macos --linkopt=-stdlib=libc++

# Windows (explicit config also used in CI)
build:windows --workspace_status_command=tools/workspace_status.bat
build:windows --cxxopt=/std:c++17
build:windows --host_cxxopt=/std:c++17
build:windows --enable_runfiles
build:windows --shell_executable=C:/Progra~1/Git/bin/bash.exe
build:windows --repo_env=BAZEL_SH=C:/Progra~1/Git/bin/bash.exe
build:windows --repo_env=BAZEL_VS
build:windows --repo_env=BAZEL_VC
build:windows --repo_env=BAZEL_VC_FULL_VERSION
build:windows --repo_env=BAZEL_WINSDK_FULL_VERSION
test:windows --repo_env=BAZEL_SH=C:/Progra~1/Git/bin/bash.exe
test:windows --enable_runfiles

# Java: use Bazel-managed remote JDK (no local JDK required)
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21

# Telemetry disabled by default
build --define enable_telemetry=false

# Test output
test --test_output=errors

# Debug config: stream test output, no caching
test:debug --test_output=streamed
test:debug --nocache_test_results
test:debug --test_strategy=exclusive

# AddressSanitizer config
build:asan --copt=-g
build:asan --copt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer
build:asan --linkopt=-fsanitize=address
build:asan --strip=never
build:asan --compilation_mode=dbg

# Deterministic floating-point for FusedExpression parity tests.
build:parity --copt=-ffp-contract=off
build:parity --copt=-fno-associative-math

# Enable xsimd-backed inner loops in the batched fused-expression evaluator.
# Off by default; opt in with `--config=fuse_simd`. On arm64 (Apple Silicon,
# aarch64 Linux) xsimd automatically targets NEON double-precision. On x86 /
# Linux, add `--copt=-mavx2` to lift above the SSE baseline. WASM targets
# need `-msimd128` in the Emscripten build.
build:fuse_simd --copt=-DRTBOT_FUSED_SIMD=1

# Emscripten flags (non-Windows)
build:linux --action_env=EMCC_CFLAGS="-fexceptions -Wno-c++11-narrowing -Wno-unused-const-variable"
build:macos --action_env=EMCC_CFLAGS="-fexceptions -Wno-c++11-narrowing -Wno-unused-const-variable"

# TypeScript
build --@aspect_rules_ts//ts:skipLibCheck=always
fetch --@aspect_rules_ts//ts:skipLibCheck=always
query --@aspect_rules_ts//ts:skipLibCheck=always
build --@aspect_rules_ts//ts:default_to_tsc_transpiler
fetch --@aspect_rules_ts//ts:default_to_tsc_transpiler
query --@aspect_rules_ts//ts:default_to_tsc_transpiler

# Allow network (needed for npm resolution)
build --sandbox_default_allow_network
